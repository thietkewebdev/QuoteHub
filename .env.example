APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# --- Production (before go-live) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-domain.example
# Run on server after deploy: bash scripts/deploy-production.sh
# Or: composer production:migrate && composer production:optimize
# Render (Docker): use render.yaml — set APP_KEY (php artisan key:generate --show) and APP_URL=https://<service>.onrender.com; DB_URL from managed Postgres. Web preDeploy: composer render:predeploy (see composer.json). Worker: queue:work. Render sets CACHE_STORE=file so queue workers do not require the `cache` DB table before migrate finishes.
# Native PaaS PHP (no Docker): keep queue worker running: php artisan queue:work (see Procfile)
# Cron: * * * * * php /path/to/artisan schedule:run

# Vietnamese UI: Filament + app strings use lang/vi.json when locale is vi.
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Ingestion uploads (per-file max size in KB; disk must match config/filesystems.php)
# INGESTION_MAX_FILE_KB=20480
# INGESTION_STORAGE_DISK=local
# INGESTION_VIEW_BATCH_POLL_SECONDS=3
# Google OCR for PDF/images: queued OCR jobs + raw capture after upload (needs GCP + GOOGLE_APPLICATION_CREDENTIALS). Set false to use Tesseract only.
# INGESTION_GOOGLE_OCR=true
# INGESTION_GOOGLE_OCR_AFTER_UPLOAD=true
# Orphan quotations (batch_id points to deleted batch): php artisan quotehub:prune-quotations-missing-batch  (add --force to delete)

# Quotation AI — see config/quotation_ai.php (openai = real OCR→JSON; mock = stub for tests)
# QUOTATION_AI_DRIVER=openai
# QUOTATION_EXTRACTION_PIPELINE=llm_table
#   hybrid — parser/table rows first; LLM normalizes rows only (see App\Services\Quotation\HybridExtraction)
# After AI extraction, sync Filament review draft from extraction_json (fallback env: QUOTATION_HYBRID_SEED_REVIEW_DRAFT)
# QUOTATION_REVIEW_DRAFT_SEED_FROM_AI=true
# QUOTATION_PROMPT_VERSION=v6-vietnamese-table-numerics
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
# OPENAI_QUOTATION_MODEL=gpt-5-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT=120
#
# LLM OCR refinement before extraction (default off; pipeline uses Google structured OCR only)
# QUOTATION_AI_OCR_REFINEMENT=false
# QUOTATION_AI_OCR_REFINEMENT_MODEL=
# QUOTATION_AI_OCR_REFINEMENT_MAX_CHARS=12000
# QUOTATION_AI_OCR_REFINEMENT_TIMEOUT=
# QUOTATION_AI_OCR_REFINEMENT_TEMPERATURE=
#
# Post-extraction spacing for line descriptions (raw_name, specs, …)
# QUOTATION_AI_LINE_TEXT_REGEX=true
# QUOTATION_AI_LINE_TEXT_GLUE_MAP=true
# QUOTATION_AI_LINE_TEXT_LLM=true
# QUOTATION_AI_LINE_TEXT_MODEL=
# QUOTATION_AI_LINE_TEXT_MAX_FIELD_CHARS=4000
# Move long spec tail from raw_name → specs_text after OCR glue pass
# QUOTATION_AI_PRODUCT_SPECS_SPLIT=true
# QUOTATION_AI_PRODUCT_SPECS_SPLIT_MIN_LEN=80
# Per-unit tax: match tax_per_unit/unit_price to 8% or 10% within this absolute ratio delta
# QUOTATION_AI_VAT_PER_UNIT_RATIO_TOL=0.004
# OPENAI_QUOTATION_TEMPERATURE=0.1
# (leave unset for gpt-5-* — those models reject custom temperature)

# OCR (Tesseract must be on PATH or set binary; scanned PDFs need PHP Imagick + Ghostscript)
# TESSERACT_BINARY=tesseract
# TESSERACT_LANG=eng
# TESSERACT_TIMEOUT=120
# OCR_MAX_PDF_PAGES=15
# OCR_PDF_RASTER_DPI=200
#
# Google Cloud OCR (optional; not wired into ingestion until validated). Test: php artisan quotehub:test-google-ocr path/to/file.pdf
# GOOGLE_OCR_ENABLED=false
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_OCR_CREDENTIALS_PATH=storage/app/google-service-account.json
# GOOGLE_DOCUMENT_AI_PROCESSOR_NAME=projects/PROJECT/locations/us/processors/PROCESSOR_ID
# GOOGLE_VISION_MODEL=
#
# App\Services\OCR\* (Vision + Document AI router) — config/services.php key "gcp"
# GCP_PROJECT_ID=
# GCP_LOCATION=us
# GCP_DOCUMENT_AI_PROCESSOR_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
